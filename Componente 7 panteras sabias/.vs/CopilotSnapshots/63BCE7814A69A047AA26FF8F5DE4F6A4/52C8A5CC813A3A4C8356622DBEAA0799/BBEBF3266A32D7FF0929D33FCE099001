using UnityEngine;

public class wario : MonoBehaviour
{
    [Header("Configuración de Salto")]
    public float fuerzaSalto = 5f; // Ajusta este valor para saltar más alto o más bajo

    private Rigidbody rb;

    void Start()
    {
        // Obtenemos el componente Rigidbody adjunto a este objeto
        rb = GetComponent<Rigidbody>();
    }

    void Update()
    {
        // Comprobamos si se presiona la tecla V
        if (Input.GetKeyDown(KeyCode.V))
        {
            Saltar();
        }
    }

    void Saltar()
    {
        // Solo saltamos si tenemos el componente Rigidbody
        if (rb != null)
        {
            // Aplicamos un impulso hacia arriba
            rb.AddForce(Vector3.up * fuerzaSalto, ForceMode.Impulse);
        }
        else
        {
            Debug.LogWarning("¡Falta añadir un Rigidbody al objeto de Wario!");
        }
    }
}
